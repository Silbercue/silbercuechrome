{
  "name": "@silbercuechrome/mcp",
  "version": "0.1.0",
  "description": "SilbercueChrome MCP Server — Chrome browser automation via CDP",
  "type": "module",
  "bin": {
    "silbercuechrome": "./build/index.js"
  },
  "main": "./build/index.js",
  "exports": {
    ".": "./build/index.js",
    "./hooks": "./build/hooks/index.js",
    "./license/license-status.js": "./build/license/license-status.js",
    "./types.js": "./build/types.js",
    "./plan/plan-executor.js": "./build/plan/plan-executor.js",
    "./plan/plan-variables.js": "./build/plan/plan-variables.js"
  },
  "scripts": {
    "build": "tsc && chmod +x build/index.js",
    "test": "vitest run",
    "token-count": "node scripts/token-count.mjs",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\"",
    "benchmark": "node test-hardest/benchmark-full.mjs",
    "publish:release": "tsx scripts/publish.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^22",
    "eslint": "^9",
    "prettier": "^3",
    "tsx": "^4.21.0",
    "typescript": "^5.7",
    "typescript-eslint": "^8",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "UNLICENSED",
  "private": true
}
